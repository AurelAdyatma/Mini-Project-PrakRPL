<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="manajemenmusik.controller.MainController"
            style="-fx-background-color: #FFFFFF; -fx-font-family: 'Segoe UI', Arial, sans-serif;">

    <!-- ==================== HEADER (TOP) ==================== -->
    <top>
        <HBox spacing="14" alignment="CENTER_LEFT"
              style="-fx-background-color: #232334;
                     -fx-border-color: transparent transparent #1a1a26 transparent;
                     -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="10" right="24" bottom="10" left="20"/>
            </padding>

            <!-- Removed Icon -->

            <VBox spacing="1">
                <Label text="MusikApp"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
                <Label text="Music Manager"
                       style="-fx-font-size: 10px; -fx-text-fill: #9CA3AF;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="tfSearch" promptText="Cari judul, artis, genre..." prefWidth="320"
                       style="-fx-background-color: #35354A; -fx-background-radius: 20;
                              -fx-border-color: transparent; -fx-border-radius: 20;
                              -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #9CA3AF;
                              -fx-padding: 9 16; -fx-font-size: 13px; -fx-pref-height: 38;"/>

            <Label text="admin"
                   style="-fx-text-fill: #E5E7EB; -fx-font-size: 13px; -fx-padding: 0 4;"/>
        </HBox>
    </top>

    <!-- ==================== SIDEBAR (LEFT) ==================== -->
    <left>
        <VBox spacing="3" prefWidth="240"
              style="-fx-background-color: #F9FAFB;
                     -fx-border-color: transparent #E5E7EB transparent transparent;
                     -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="14" right="8" bottom="14" left="8"/>
            </padding>

            <Label text="MENU"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6B7280;
                          -fx-padding: 6 14 2 14;"/>

            <Button fx:id="btnNavPustaka" text="Perpustakaan" onAction="#onNavPustaka"
                    prefWidth="224" alignment="CENTER_LEFT"
                    style="-fx-background-color: #FFFFFF; -fx-background-radius: 6;
                           -fx-text-fill: #111827; -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 10 14;
                           -fx-border-color: transparent transparent transparent #10B981;
                           -fx-border-width: 0 0 0 4;"/>

            <Button fx:id="btnNavFavorit" text="♥    Favorit" onAction="#onNavFavorit"
                    prefWidth="224" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-background-radius: 6;
                           -fx-text-fill: #4B5563; -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 10 14;"/>

            <Button fx:id="btnNavPlaylist" text="Playlist" onAction="#onNavPlaylist"
                    prefWidth="224" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-background-radius: 6;
                           -fx-text-fill: #4B5563; -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 10 14;"/>

            <Label text="TOOLS"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #6B7280;
                          -fx-padding: 18 14 2 14;"/>

            <Button fx:id="btnNavStatistik" text="Statistik" onAction="#onNavStatistik"
                    prefWidth="224" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-background-radius: 6;
                           -fx-text-fill: #4B5563; -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 10 14;"/>

            <Button fx:id="btnNavIO" text="Import / Export" onAction="#onNavIO"
                    prefWidth="224" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-background-radius: 6;
                           -fx-text-fill: #4B5563; -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 10 14;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="btnLogout" text="Logout" onAction="#onLogout"
                    prefWidth="224" alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent; -fx-background-radius: 6;
                           -fx-text-fill: #EF4444; -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 10 14;"/>

            <Label text="v2.1.0  •  MusikApp"
                   style="-fx-text-fill: #9CA3AF; -fx-font-size: 10px; -fx-padding: 0 14;"/>
        </VBox>
    </left>

    <!-- ==================== CONTENT (CENTER) ==================== -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #FFFFFF;">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <!-- ========== PANEL PERPUSTAKAAN ========== -->
            <VBox fx:id="panelPustaka" spacing="16" visible="true" managed="true">

                <!-- Title + Filter Row -->
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label text="Perpustakaan Musik"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label text="Kelola seluruh koleksi musikmu di sini."
                               style="-fx-font-size: 13px; -fx-text-fill: #4B5563;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Filter Genre:"
                               style="-fx-text-fill: #4B5563; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="cbGenre" prefWidth="170" prefHeight="36"
                                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 6;
                                         -fx-border-color: #D1D5DB; -fx-border-radius: 6;
                                         -fx-padding: 2 6;"/>
                    </HBox>
                </HBox>

                <!-- Table + Form -->
                <HBox spacing="20" VBox.vgrow="ALWAYS">

                    <!-- Tabel Pustaka -->
                    <TableView fx:id="tabelPustaka" HBox.hgrow="ALWAYS"
                               style="-fx-background-color: transparent; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6;">
                        <placeholder>
                            <Label text="Belum ada data lagu"
                                   style="-fx-text-fill: #9CA3AF; -fx-font-size: 14px;"/>
                        </placeholder>
                        <columns>
                            <TableColumn fx:id="colNoPustaka" text="#" prefWidth="45" sortable="false"/>
                            <TableColumn fx:id="colIdPustaka" text="ID" prefWidth="65"/>
                            <TableColumn fx:id="colJudulPustaka" text="JUDUL" prefWidth="210"/>
                            <TableColumn fx:id="colArtisPustaka" text="ARTIS" prefWidth="160"/>
                            <TableColumn fx:id="colGenrePustaka" text="GENRE" prefWidth="90"/>
                            <TableColumn fx:id="colDurasiPustaka" text="DURASI" prefWidth="80"/>
                            <TableColumn fx:id="colTahunPustaka" text="TAHUN" prefWidth="75"/>
                            <TableColumn fx:id="colFavPustaka" text="♥" prefWidth="55" sortable="false"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
                        </columnResizePolicy>
                    </TableView>

                    <!-- Form Card -->
                    <VBox fx:id="formCard" spacing="10" prefWidth="310" minWidth="310" maxWidth="310"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10;">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>

                        <Label text="Data Lagu"
                               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Separator style="-fx-background-color: #E5E7EB; -fx-min-height: 1;"/>

                        <!-- ID -->
                        <VBox spacing="4">
                            <Label text="ID LAGU"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold;
                                          -fx-text-fill: #4B5563; -fx-padding: 2 0 0 0;"/>
                            <TextField fx:id="tfId" promptText="Contoh: 1025" prefHeight="38"
                                       maxWidth="1.7976931348623157E308"
                                       style="-fx-background-color: #FFFFFF; -fx-background-radius: 6;
                                              -fx-border-color: #D1D5DB; -fx-border-radius: 6;
                                              -fx-text-fill: #111827; -fx-prompt-text-fill: #9CA3AF;
                                              -fx-padding: 9 12; -fx-font-size: 13px;"/>
                        </VBox>

                        <!-- Judul -->
                        <VBox spacing="4">
                            <Label text="JUDUL LAGU"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold;
                                          -fx-text-fill: #4B5563; -fx-padding: 2 0 0 0;"/>
                            <TextField fx:id="tfJudul" promptText="Masukkan judul..." prefHeight="38"
                                       maxWidth="1.7976931348623157E308"
                                       style="-fx-background-color: #FFFFFF; -fx-background-radius: 6;
                                              -fx-border-color: #D1D5DB; -fx-border-radius: 6;
                                              -fx-text-fill: #111827; -fx-prompt-text-fill: #9CA3AF;
                                              -fx-padding: 9 12; -fx-font-size: 13px;"/>
                        </VBox>

                        <!-- Artis -->
                        <VBox spacing="4">
                            <Label text="ARTIS"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold;
                                          -fx-text-fill: #4B5563; -fx-padding: 2 0 0 0;"/>
                            <TextField fx:id="tfArtis" promptText="Nama artis..." prefHeight="38"
                                       maxWidth="1.7976931348623157E308"
                                       style="-fx-background-color: #FFFFFF; -fx-background-radius: 6;
                                              -fx-border-color: #D1D5DB; -fx-border-radius: 6;
                                              -fx-text-fill: #111827; -fx-prompt-text-fill: #9CA3AF;
                                              -fx-padding: 9 12; -fx-font-size: 13px;"/>
                        </VBox>

                        <!-- Genre -->
                        <VBox spacing="4">
                            <Label text="GENRE"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold;
                                          -fx-text-fill: #4B5563; -fx-padding: 2 0 0 0;"/>
                            <TextField fx:id="tfGenre" promptText="Pop, Rock, Indie..." prefHeight="38"
                                       maxWidth="1.7976931348623157E308"
                                       style="-fx-background-color: #FFFFFF; -fx-background-radius: 6;
                                              -fx-border-color: #D1D5DB; -fx-border-radius: 6;
                                              -fx-text-fill: #111827; -fx-prompt-text-fill: #9CA3AF;
                                              -fx-padding: 9 12; -fx-font-size: 13px;"/>
                        </VBox>

                        <!-- Durasi -->
                        <VBox spacing="4">
                            <Label text="DURASI (MENIT)"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold;
                                          -fx-text-fill: #4B5563; -fx-padding: 2 0 0 0;"/>
                            <TextField fx:id="tfDurasi" promptText="Contoh: 4" prefHeight="38"
                                       maxWidth="1.7976931348623157E308"
                                       style="-fx-background-color: #FFFFFF; -fx-background-radius: 6;
                                              -fx-border-color: #D1D5DB; -fx-border-radius: 6;
                                              -fx-text-fill: #111827; -fx-prompt-text-fill: #9CA3AF;
                                              -fx-padding: 9 12; -fx-font-size: 13px;"/>
                        </VBox>

                        <!-- Tahun -->
                        <VBox spacing="4">
                            <Label text="TAHUN RILIS"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold;
                                          -fx-text-fill: #4B5563; -fx-padding: 2 0 0 0;"/>
                            <TextField fx:id="tfTahun" promptText="Contoh: 2024" prefHeight="38"
                                       maxWidth="1.7976931348623157E308"
                                       style="-fx-background-color: #FFFFFF; -fx-background-radius: 6;
                                              -fx-border-color: #D1D5DB; -fx-border-radius: 6;
                                              -fx-text-fill: #111827; -fx-prompt-text-fill: #9CA3AF;
                                              -fx-padding: 9 12; -fx-font-size: 13px;"/>
                        </VBox>

                        <Separator style="-fx-background-color: #E5E7EB; -fx-min-height: 1;"/>

                        <!-- Buttons -->
                        <Button fx:id="btnTambah" text="Tambah Lagu" onAction="#onTambahLagu"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: #10B981; -fx-background-radius: 20;
                                       -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-cursor: hand; -fx-padding: 9 22;"/>

                        <Button fx:id="btnEdit" text="Simpan Perubahan" onAction="#onEditLagu"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: #D97706; -fx-background-radius: 20;
                                       -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-cursor: hand; -fx-padding: 9 22;"/>

                        <Button fx:id="btnHapus" text="Hapus Lagu" onAction="#onHapusLagu"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: #EF4444; -fx-background-radius: 20;
                                       -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-cursor: hand; -fx-padding: 9 22;"/>

                        <Button fx:id="btnReset" text="Bersihkan Form" onAction="#onBersihkanForm"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: transparent; -fx-background-radius: 20;
                                       -fx-border-color: #D1D5DB; -fx-border-radius: 20; -fx-border-width: 1;
                                       -fx-text-fill: #4B5563; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-cursor: hand; -fx-padding: 8 21;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ========== PANEL FAVORIT ========== -->
            <VBox fx:id="panelFavorit" spacing="16" visible="false" managed="false">
                <Label text="♥  Lagu Favorit"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <Label text="Klik ikon ♥ pada tabel untuk menambah atau menghapus lagu dari favorit."
                       wrapText="true"
                       style="-fx-font-size: 13px; -fx-text-fill: #4B5563;"/>

                <TableView fx:id="tabelFavorit" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6;">
                    <placeholder>
                        <Label text="Belum ada lagu favorit"
                               style="-fx-text-fill: #9CA3AF; -fx-font-size: 14px;"/>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="colNoFav" text="#" prefWidth="45" sortable="false"/>
                        <TableColumn fx:id="colIdFav" text="ID" prefWidth="65"/>
                        <TableColumn fx:id="colJudulFav" text="JUDUL" prefWidth="210"/>
                        <TableColumn fx:id="colArtisFav" text="ARTIS" prefWidth="160"/>
                        <TableColumn fx:id="colGenreFav" text="GENRE" prefWidth="90"/>
                        <TableColumn fx:id="colDurasiFav" text="DURASI" prefWidth="80"/>
                        <TableColumn fx:id="colTahunFav" text="TAHUN" prefWidth="75"/>
                        <TableColumn fx:id="colFavFav" text="♥" prefWidth="55" sortable="false"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- ========== PANEL PLAYLIST ========== -->
            <VBox fx:id="panelPlaylist" spacing="16" visible="false" managed="false">
                <Label text="Manajemen Playlist"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                <HBox spacing="20" VBox.vgrow="ALWAYS">

                    <!-- Left: Daftar Playlist -->
                    <VBox spacing="12" prefWidth="260" minWidth="260"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10;">
                        <padding>
                            <Insets top="18" right="18" bottom="18" left="18"/>
                        </padding>

                        <Label text="Daftar Playlist"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                        <ListView fx:id="listViewPlaylist" VBox.vgrow="ALWAYS"
                                  style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB;
                                         -fx-background-radius: 8; -fx-border-radius: 8;"/>

                        <TextField fx:id="tfPlaylistNama" promptText="Nama playlist baru..." prefHeight="38"
                                   maxWidth="1.7976931348623157E308"
                                   style="-fx-background-color: #FFFFFF; -fx-background-radius: 6;
                                          -fx-border-color: #D1D5DB; -fx-border-radius: 6;
                                          -fx-text-fill: #111827; -fx-prompt-text-fill: #9CA3AF;
                                          -fx-padding: 9 12; -fx-font-size: 13px;"/>

                        <Button text="Buat Playlist" onAction="#onBuatPlaylist"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: #10B981; -fx-background-radius: 20;
                                       -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-cursor: hand; -fx-padding: 9 22;"/>

                        <Button text="Hapus Playlist" onAction="#onHapusPlaylist"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: #EF4444; -fx-background-radius: 20;
                                       -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-cursor: hand; -fx-padding: 9 22;"/>
                    </VBox>

                    <!-- Right: Isi Playlist -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10;">
                        <padding>
                            <Insets top="18" right="18" bottom="18" left="18"/>
                        </padding>

                        <Label text="Isi Playlist"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                        <Label text="Pilih playlist di kiri, lalu pilih lagu dari Perpustakaan, kemudian klik Tambahkan."
                               wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #4B5563;"/>

                        <TableView fx:id="tabelPlaylistSong" VBox.vgrow="ALWAYS"
                                   style="-fx-background-color: transparent; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6;">
                            <placeholder>
                                <Label text="Pilih playlist untuk melihat isi"
                                       style="-fx-text-fill: #9CA3AF; -fx-font-size: 14px;"/>
                            </placeholder>
                            <columns>
                                <TableColumn fx:id="colNoPl" text="#" prefWidth="45" sortable="false"/>
                                <TableColumn fx:id="colIdPl" text="ID" prefWidth="65"/>
                                <TableColumn fx:id="colJudulPl" text="JUDUL" prefWidth="210"/>
                                <TableColumn fx:id="colArtisPl" text="ARTIS" prefWidth="160"/>
                                <TableColumn fx:id="colGenrePl" text="GENRE" prefWidth="90"/>
                                <TableColumn fx:id="colDurasiPl" text="DURASI" prefWidth="80"/>
                                <TableColumn fx:id="colTahunPl" text="TAHUN" prefWidth="75"/>
                                <TableColumn fx:id="colFavPl" text="♥" prefWidth="55" sortable="false"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
                            </columnResizePolicy>
                        </TableView>

                        <HBox spacing="10">
                            <Button text="Tambahkan Lagu dari Perpustakaan" onAction="#onTambahKePlaylist"
                                    maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"
                                    style="-fx-background-color: #8B5CF6; -fx-background-radius: 20;
                                           -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold;
                                           -fx-cursor: hand; -fx-padding: 9 22;"/>
                            <Button text="Hapus dari Playlist" onAction="#onHapusDariPlaylist"
                                    maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"
                                    style="-fx-background-color: #EF4444; -fx-background-radius: 20;
                                           -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold;
                                           -fx-cursor: hand; -fx-padding: 9 22;"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ========== PANEL STATISTIK ========== -->
            <VBox fx:id="panelStatistik" spacing="22" visible="false" managed="false">
                <Label text="Statistik Musik"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                <!-- Stat Cards -->
                <HBox spacing="16">
                    <!-- Total Lagu -->
                    <VBox spacing="6" alignment="TOP_LEFT" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #ECFDF5; -fx-background-radius: 12;
                                 -fx-border-radius: 12; -fx-border-color: #A7F3D0;
                                 -fx-border-width: 1; -fx-padding: 20;">
                        <Label fx:id="lblStatTotal" text="0"
                               style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                        <Label text="Total Lagu"
                               style="-fx-font-size: 12px; -fx-text-fill: #047857; -fx-font-weight: bold;"/>
                    </VBox>

                    <!-- Total Artis -->
                    <VBox spacing="6" alignment="TOP_LEFT" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #F5F3FF; -fx-background-radius: 12;
                                 -fx-border-radius: 12; -fx-border-color: #DDD6FE;
                                 -fx-border-width: 1; -fx-padding: 20;">
                        <Label fx:id="lblStatArtis" text="0"
                               style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #7C3AED;"/>
                        <Label text="Total Artis"
                               style="-fx-font-size: 12px; -fx-text-fill: #6D28D9; -fx-font-weight: bold;"/>
                    </VBox>

                    <!-- Total Genre -->
                    <VBox spacing="6" alignment="TOP_LEFT" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #EFF6FF; -fx-background-radius: 12;
                                 -fx-border-radius: 12; -fx-border-color: #BFDBFE;
                                 -fx-border-width: 1; -fx-padding: 20;">
                        <Label fx:id="lblStatGenre" text="0"
                               style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #2563EB;"/>
                        <Label text="Total Genre"
                               style="-fx-font-size: 12px; -fx-text-fill: #1D4ED8; -fx-font-weight: bold;"/>
                    </VBox>

                    <!-- Favorit -->
                    <VBox spacing="6" alignment="TOP_LEFT" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #FEF2F2; -fx-background-radius: 12;
                                 -fx-border-radius: 12; -fx-border-color: #FCA5A5;
                                 -fx-border-width: 1; -fx-padding: 20;">
                        <Label fx:id="lblStatFavorit" text="0"
                               style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #DC2626;"/>
                        <Label text="♥   Favorit"
                               style="-fx-font-size: 12px; -fx-text-fill: #B91C1C; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>

                <Label text="Distribusi Genre"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent; -fx-background-color: transparent;">
                    <VBox fx:id="genreStatBox" spacing="12"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10;">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- ========== PANEL IMPORT / EXPORT ========== -->
            <VBox fx:id="panelImportExport" spacing="24" maxWidth="600" visible="false" managed="false">
                <Label text="Import &amp; Export Data"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                <!-- Export Card -->
                <VBox spacing="14"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10;">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <Label text="Export ke CSV"
                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                    <Label text="Simpan seluruh data lagu ke file CSV. File dapat dibuka dengan Microsoft Excel atau Google Sheets."
                           wrapText="true"
                           style="-fx-font-size: 13px; -fx-text-fill: #4B5563;"/>

                    <Button text="Export Semua Lagu ke CSV" onAction="#onExportCSV"
                            style="-fx-background-color: #10B981; -fx-background-radius: 20;
                                   -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-cursor: hand; -fx-padding: 9 22;"/>
                </VBox>

                <!-- Import Card -->
                <VBox spacing="14"
                      style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 10;">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <Label text="Import dari CSV"
                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                    <Label wrapText="true"
                           text="Muat data lagu dari file CSV. Format kolom: ID, Judul, Artis, Genre, Durasi, Tahun, Favorit (opsional). Data akan ditambahkan ke perpustakaan yang sudah ada. Lagu dengan ID yang sama akan dilewati."
                           style="-fx-font-size: 13px; -fx-text-fill: #4B5563;"/>

                    <Button text="Import Lagu dari CSV" onAction="#onImportCSV"
                            style="-fx-background-color: #8B5CF6; -fx-background-radius: 20;
                                   -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-cursor: hand; -fx-padding: 9 22;"/>
                </VBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
